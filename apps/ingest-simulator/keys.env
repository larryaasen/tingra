# Test stream keys for the local ingest simulator (see docs/SIMULATOR.md).
# Fake values, deliberately committed — the simulator validates keys by path,
# and these are the only paths mediamtx.yml defines. Any other key is
# rejected at connect time, which is the bad-stream-key test scenario.
#
# Usage: source this file, then e.g.
#   tingra-cli stream --url rtmp://localhost:1935/live --key-env TINGRA_TEST_KEY \
#     --video-generator bars --audio-generator tone --duration 30

# The valid key (Twitch shaped: rtmp://localhost:1935/live/{key},
# YouTube shaped: rtmp://localhost:1935/live2/{key}, SRT:
# srt://localhost:8890?streamid=publish:live/{key}).
TINGRA_TEST_KEY=tingra_test_key

# A key no path defines — publishing with it is rejected, exercising the
# CLI's connectionFailed path (exit 75).
TINGRA_BAD_KEY=wrong_key
